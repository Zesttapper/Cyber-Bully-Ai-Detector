{
  "manifest_version": 3,
  "name": "CyberShield - Anti-CyberBullying",
  "version": "0.1",
  "description": "Detects insults and reduces Cyber-bullying In Real Time Made By : Mazen Mohammed Ali",
  "permissions": ["activeTab", "storage","tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberShield"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css" :["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
